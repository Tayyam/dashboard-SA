# Frontend (Vite) — copy to .env for local dev
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
# When the API is on another origin (production). Leave unset in dev to use Vite proxy /api → localhost:8787
# VITE_API_URL=https://api.yourdomain.com

# Backend (server/) — same .env file works: server loads ../../.env
PORT=8787
EMBED_SECRET=use_a_long_random_secret
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_EMBED_USER_EMAIL=embed-manager@yourdomain.com
SUPABASE_EMBED_USER_PASSWORD=strong_password_only_on_server
CORS_ORIGINS=http://localhost:5173,http://svdashboard.duckdns.org,https://svdashboard.duckdns.org
# مؤقت: 1 = السماح بأي Origin (إلغاء تقييد CORS). احذف أو ضع 0 في الإنتاج.
# DISABLE_CORS=0
